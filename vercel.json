{
  "buildCommand": "cd soc-dashboard && npm run build",
  "outputDirectory": "soc-dashboard/.next",
  "installCommand": "cd soc-dashboard && npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-url.onrender.com/api/:path*"
    }
  ]
}
